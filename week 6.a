#include <iostream>
using namespace std;

const int MAX = 100;

bool dfs(int graph[MAX][MAX], bool visited[], int n, int current, int dest) {
    // If current vertex is destination
    if (current == dest)
        return true;

    visited[current] = true;

    // Visit all adjacent vertices
    for (int i = 0; i < n; i++) {
        if (graph[current][i] == 1 && !visited[i]) {
            if (dfs(graph, visited, n, i, dest))
                return true;
        }
    }

    return false;
}

int main() {
    int n;
    cout << "Enter number of vertices: ";
    cin >> n;

    int graph[MAX][MAX];

    cout << "Enter adjacency matrix:\n";
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            cin >> graph[i][j];

    int source, dest;
    cout << "Enter source and destination: ";
    cin >> source >> dest;

    bool visited[MAX] = {false};

    if (dfs(graph, visited, n, source, dest))
        cout << "Yes Path Exists";
    else
        cout << "No Such Path Exists";

    return 0;
} 
